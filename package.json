{
  "name": "visa-and-voyage-root",
  "version": "1.0.0",
  "description": "Premium Visa Application Platform",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "build": "npm install --prefix client && npm run build --prefix client && npm install --prefix admin && npm run build --prefix admin && npm install --prefix server",
    "client": "npm run dev --prefix client",
    "admin": "npm run dev --prefix admin",
    "server": "node server/server.js",
    "images:pinterest": "npm --prefix server run images:pinterest --",
    "db:sync-countries": "npm --prefix server run seed:countries:sync",
    "db:images-unsplash": "npm --prefix server run images:countries",
    "db:images-unsplash:missing": "npm --prefix server run images:countries:missing",
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run admin\"",
    "generate:country-regions": "npm run generate:country-regions --prefix server"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
