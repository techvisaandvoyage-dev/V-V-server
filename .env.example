# Copy to .env and fill in. Email OTP (signup, login, forgot password) needs SMTP below
# OR configure "Email OTP (SMTP)" in Admin → Settings (stored in Mongo; overrides these when set).
# You may split: Admin SMTP user + EMAIL_PASS here, or EMAIL_USER here + Admin SMTP password (see server/utils/sendEmail.js).

# Nodemailer (Gmail: use an App Password, not your normal password)
EMAIL_SERVICE=gmail
EMAIL_USER=your-address@gmail.com
EMAIL_PASS=your-app-password

# Optional — Google Workspace only: send via Gmail OAuth2 using the same JSON as Firebase Admin.
# EMAIL_SERVICE=gmail-oauth
# EMAIL_USER=delegated-mailbox@yourdomain.com
# EMAIL_PASS=
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Phone login OTP is ON by default (requires SMS91 for real SMS). Set to false to allow only email OTP.
# ENABLE_PHONE_LOGIN_OTP=false

# Optional overrides
# EMAIL_SERVICE=SendGrid
# (configure nodemailer transport accordingly if not using Gmail)

# ExchangeRate-API (backend only; used by Admin -> Fee Update Manager)
# EXCHANGE_RATE_API_KEY=

# JWT & Mongo (your existing vars)
# JWT_SECRET=
# MONGO_URI=

# Comma-separated browser origins allowed to call the API.
# Defaults already include visavo.in, www.visavo.in, admin.visavo.in, www.admin.visavo.in, and local Vite ports.
# CORS_ORIGINS=https://visavo.in,https://www.visavo.in,https://admin.visavo.in

# Firebase Admin SDK — required for verifying Google / Firebase ID tokens (not editable in Admin UI).
# Option A — point at the downloaded JSON file (easiest for local dev; add filename to .gitignore).
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-adminsdk.json
# Option B — inline JSON (one line in .env, or multiline on Render secret editor).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: same web app values as Admin → Firebase (if you prefer env over DB for public client config)
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=

# SMS91 (phone OTP) — optional; can also be set in admin Settings
# SMS91_AUTHKEY=
# SMS91_TEMPLATE_ID=

# Unsplash — country card images in Mongo (Admin → Settings → Fetch images, or node fetchCountryImages.js)
# Prefer Admin → Settings → Country images (Unsplash); env overrides only if DB key is empty.
# https://unsplash.com/oauth/applications → create app → Access Key (Secret Key is for OAuth only)
# UNSPLASH_ACCESS_KEY=
# Milliseconds between Unsplash API calls (rate limits). Default 900.
# UNSPLASH_DELAY_MS=900
# Optional: batch size for CLI loop (default 25). Admin API uses 25 per request.
# UNSPLASH_BATCH_SIZE=25
# Optional: portrait | landscape | squarish — if unset, Unsplash uses the same mixed results as the website search (recommended).
# UNSPLASH_ORIENTATION=

# Pinterest — optional alternative (node fetchPinterestCountryImages.js)
# PINTEREST_ACCESS_TOKEN=
# PINTEREST_BOARD_ID=

# Legacy Pexels (replaced by Unsplash in fetchCountryImages.js)
# PEXELS_API_KEY=

# OpenStreetMap Nominatim (city/state → country search). Optional User-Agent string per https://operations.osmfoundation.org/policies/nominatim/
# NOMINATIM_USER_AGENT=YourApp/1.0 (your@email.com)
# Max place rows returned per query (city list). Default 25, max 40.
# GEOCODE_PLACES_CAP=25
